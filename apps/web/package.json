{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate --schema=prisma/schema.prisma && next build",
    "sentry:release": "npx sentry-cli releases new $npm_package_version && npx sentry-cli releases files $npm_package_version upload-sourcemaps .next --rewrite",
    "start": "next start",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:duplicate-api-routes": "node scripts/check-duplicate-api-routes.js",
    "prelint": "npm run check:duplicate-api-routes",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma --name init",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@lovedate/api": "file:../../packages/api",
    "@lovedate/ui": "file:../../packages/ui",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.12.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^10.0.0",
    "hot-shots": "^12.0.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.268.0",
    "next": "14.2.11",
    "next-auth": "^4.24.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resolve": "^1.22.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.7",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
