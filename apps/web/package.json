{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5001",
    "build": "node ../../scripts/run-prisma-from-root.mjs generate && next build",
    "build:analyze": "ANALYZE=true next build",
    "sentry:release": "npx sentry-cli releases new $npm_package_version && npx sentry-cli releases files $npm_package_version upload-sourcemaps .next --rewrite",
    "start": "next start",
    "start:playwright": "cross-env PORT=4000 next start",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:admin-playwright": "cross-env PLAYWRIGHT_START_SERVER=0 PLAYWRIGHT_BASE_URL=http://localhost:4000 playwright test e2e/admin-dashboard.spec.ts",
    "typecheck": "tsc --noEmit",
    "check:duplicate-api-routes": "node scripts/check-duplicate-api-routes.js",
    "prelint": "npm run check:duplicate-api-routes",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx --max-warnings=0 .",
    "prisma:generate": "node ../../scripts/run-prisma-from-root.mjs generate",
    "prisma:migrate:dev": "node ../../scripts/run-prisma-from-root.mjs migrate dev --name init",
    "postinstall": "node ../../scripts/run-prisma-from-root.mjs generate",
    "perf:lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html && echo 'Report saved to lighthouse-report.html'"
  },
  "dependencies": {
    "@lovedate/api": "file:../../packages/api",
    "@lovedate/ui": "file:../../packages/ui",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/node": "^8.12.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "baseline-browser-mapping": "^2.10.0",
    "bcryptjs": "^3.0.3",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001774",
    "cloudinary": "^1.41.0",
    "framer-motion": "^10.18.0",
    "hot-shots": "^12.0.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.268.0",
    "motion": "^10.18.0",
    "next": "^16.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resolve": "^1.22.1",
    "swr": "^2.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/caniuse-lite": "^1",
    "@types/node": "^20",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.7",
    "postcss": "^8.5.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
