# Docker build ignore file
# Excludes files/directories from Docker context to speed up build

# Dependencies (will be installed in image)
node_modules/
npm-debug.log*
yarn-error.log*
yarn.lock
package-lock.json

# Build outputs
.expo/
.next/
dist/
build/
*.apk
*.aab
.gradle/

# Version control
.git/
.gitignore
.github/

# IDE files
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
.vim/

# OS files
Thumbs.db

# Temporary/cache
.turbo/
.eslintcache
.env.local
.env
cookies.txt
*.log

# Monorepo workspace files (not needed for mobile-only build)
../.git/
../../.git/
../../node_modules/
../../.turbo/
../../apps/web/
../../apps/mobile/node_modules/
../../services/
../../api/
../../infra/
../../netlify/
../../docker/
../../docs/
../../packages/
../../.github/

# Test/dev files
test-results/
.pytest_cache/
coverage/
*.test.js
