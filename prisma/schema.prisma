generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  hashedPassword       String?
  displayName          String?
  name                 String?
  age                  Int?
  birthDate            DateTime?
  location             String?
  job                  String?
  avatar               String?
  about                String?
  interests            String[]
  role                 String              @default("user")
  isVerified           Boolean             @default(false)
  banned               Boolean             @default(false)
  createdAt            DateTime            @default(now())
  onboardingCompleted  Boolean             @default(false)
  onboardingStep       String?
  profileCompletedAt   DateTime?
  gender               String?
  orientation          String?
  photos               String[]            @default([])
  lookingFor           String?
  conversationsAsOther ConversationState[] @relation("ConversationStateOther")
  conversationStates   ConversationState[]
  matchesInitiated     Match[]             @relation("UserMatches")
  matchesReceived      Match[]             @relation("TargetMatches")
  matchActions         MatchAction[]
  matchActionsTarget   MatchAction[]       @relation("MatchActionTarget")
  messagesSent         Message[]           @relation("MessagesFrom")
  messagesReceived     Message[]           @relation("MessagesTo")
  roomsCreated         Room[]              @relation("RoomCreator")
  roomMembers          RoomMember[]
  roomMessages         RoomMessage[]
  spaceMembers         SpaceMember[]
  bookmarks            Bookmark[]          @relation("UserBookmarks")
  bookmarkedBy         Bookmark[]          @relation("BookmarkedBy")
}

model Match {
  id                 String        @id @default(uuid())
  createdAt          DateTime      @default(now())
  compatibilityScore Int?
  isHighlighted      Boolean       @default(false)
  requesterId        String
  status             MatchStatus   @default(PENDING)
  tagsOverlap        Int?          @default(0)
  targetUserId       String
  updatedAt          DateTime      @default(now()) @updatedAt
  requester          User          @relation("UserMatches", fields: [requesterId], references: [id])
  target             User          @relation("TargetMatches", fields: [targetUserId], references: [id])
  actions            MatchAction[]

  @@unique([requesterId, targetUserId], map: "uniq_match_participants")
  @@index([requesterId, targetUserId], map: "idx_match_participants")
}

model MatchAction {
  id           String          @id @default(uuid())
  matchId      String?
  actorId      String
  targetUserId String
  action       MatchActionType
  createdAt    DateTime        @default(now())
  actor        User            @relation(fields: [actorId], references: [id])
  match        Match?          @relation(fields: [matchId], references: [id])
  target       User            @relation("MatchActionTarget", fields: [targetUserId], references: [id])

  @@unique([actorId, targetUserId], map: "uniq_match_action_actor_target")
  @@index([actorId, targetUserId], map: "idx_match_action_actor_target")
}

model Bookmark {
  id              String   @id @default(uuid())
  userId          String
  bookmarkedUserId String
  createdAt       DateTime @default(now())
  user            User     @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)
  bookmarkedUser  User     @relation("BookmarkedBy", fields: [bookmarkedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, bookmarkedUserId], map: "uniq_bookmark_user_target")
  @@index([userId], map: "idx_bookmark_user")
}

model Message {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  text      String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
  from      User     @relation("MessagesFrom", fields: [fromId], references: [id])
  to        User     @relation("MessagesTo", fields: [toId], references: [id])
}

model ConversationState {
  id          String    @id @default(uuid())
  userId      String
  otherUserId String
  muted       Boolean   @default(false)
  archived    Boolean   @default(false)
  lastReadAt  DateTime?
  updatedAt   DateTime  @default(now()) @updatedAt
  otherUser   User      @relation("ConversationStateOther", fields: [otherUserId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, otherUserId], map: "uniq_conversation_states_user_other")
}

model Space {
  id                String        @id @default(uuid())
  name              String        @unique
  description       String?
  createdAt         DateTime      @default(now())
  icon              String?
  orientation       String
  roomCreationLimit Int           @default(10)
  rooms             Room[]
  members           SpaceMember[]
}

model SpaceMember {
  id       String   @id @default(uuid())
  userId   String
  spaceId  String
  joinedAt DateTime @default(now())
  space    Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId], map: "uniq_space_member")
}

model Room {
  id          String        @id @default(uuid())
  name        String
  description String?
  spaceId     String
  creatorId   String
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  isGeneral   Boolean       @default(false)
  creator     User          @relation("RoomCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  members     RoomMember[]
  messages    RoomMessage[]

  @@index([spaceId], map: "idx_room_space")
  @@index([creatorId], map: "idx_room_creator")
}

model RoomMember {
  id       String   @id @default(uuid())
  userId   String
  roomId   String
  joinedAt DateTime @default(now())
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId], map: "uniq_room_member")
  @@index([roomId], map: "idx_room_member_room")
}

model RoomMessage {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId], map: "idx_room_message_room")
  @@index([userId], map: "idx_room_message_user")
}

model Audit {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  actorId   String
  action    String
  targetId  String?
  message   String?
  details   String?
}

enum MatchStatus {
  PENDING
  CONNECTED
  PASSED
}

enum MatchActionType {
  LIKE
  PASS
  BLOCK
}
