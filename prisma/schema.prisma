generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  hashedPassword     String?
  displayName        String?
  name               String?
  age                Int?
  location           String?
  job                String?
  avatar             String?
  about              String?
  interests          String[]
  gender             String?
  orientation        String?
  onboardingCompleted Boolean             @default(false)
  onboardingStep      String?
  profileCompletedAt  DateTime?
  role               String              @default("user")
  isVerified         Boolean             @default(false)
  banned             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  matchesInitiated   Match[]             @relation("UserMatches")
  matchesReceived    Match[]             @relation("TargetMatches")
  matchActions       MatchAction[]
  matchActionsTarget MatchAction[]      @relation("MatchActionTarget")
  conversationStates ConversationState[]
  conversationsAsOther ConversationState[] @relation("ConversationStateOther")
  messagesSent       Message[]           @relation("MessagesFrom")
  messagesReceived   Message[]           @relation("MessagesTo")
  spaceMembers       SpaceMember[]
  roomsCreated       Room[]              @relation("RoomCreator")
  roomMembers        RoomMember[]
  roomMessages       RoomMessage[]
}

model Match {
  id                  String        @id @default(uuid())
  requester           User          @relation("UserMatches", fields: [requesterId], references: [id])
  requesterId         String
  target              User          @relation("TargetMatches", fields: [targetUserId], references: [id])
  targetUserId        String
  status              MatchStatus   @default(PENDING)
  compatibilityScore  Int?
  tagsOverlap         Int?          @default(0)
  isHighlighted       Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  actions             MatchAction[]

  @@index([requesterId, targetUserId], map: "idx_match_participants")
}

model MatchAction {
  id         String           @id @default(uuid())
  match      Match?           @relation(fields: [matchId], references: [id])
  matchId    String?
  actor      User             @relation(fields: [actorId], references: [id])
  actorId    String
  target     User             @relation("MatchActionTarget", fields: [targetUserId], references: [id])
  targetUserId String
  action     MatchActionType
  createdAt  DateTime         @default(now())

  @@index([actorId, targetUserId], map: "idx_match_action_actor_target")
}

model Message {
  id        String   @id @default(uuid())
  from      User     @relation("MessagesFrom", fields: [fromId], references: [id])
  fromId    String
  to        User     @relation("MessagesTo", fields: [toId], references: [id])
  toId      String
  text      String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

model ConversationState {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  otherUser    User     @relation("ConversationStateOther", fields: [otherUserId], references: [id])
  otherUserId  String
  muted        Boolean  @default(false)
  archived     Boolean  @default(false)
  lastReadAt   DateTime?
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([userId, otherUserId], map: "uniq_conversation_states_user_other")
}

enum MatchStatus {
  PENDING
  CONNECTED
  PASSED
}

model Space {
  id                    String          @id @default(uuid())
  name                  String          @unique
  description           String?
  icon                  String?
  orientation           String          // "straight" or "lgbtq"
  createdAt             DateTime        @default(now())
  members               SpaceMember[]
  rooms                 Room[]
  roomCreationLimit     Int             @default(10)
}

model SpaceMember {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId   String
  joinedAt  DateTime @default(now())

  @@unique([userId, spaceId], map: "uniq_space_member")
}

model Room {
  id          String        @id @default(uuid())
  name        String
  description String?
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId     String
  creator     User          @relation("RoomCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  members     RoomMember[]
  messages    RoomMessage[]

  @@index([spaceId], map: "idx_room_space")
  @@index([creatorId], map: "idx_room_creator")
}

model RoomMember {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  joinedAt  DateTime @default(now())

  @@unique([userId, roomId], map: "uniq_room_member")
  @@index([roomId], map: "idx_room_member_room")
}

model RoomMessage {
  id        String   @id @default(uuid())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  text      String
  createdAt DateTime @default(now())

  @@index([roomId], map: "idx_room_message_room")
  @@index([userId], map: "idx_room_message_user")
}

enum MatchActionType {
  LIKE
  PASS
  BLOCK
}

model Audit {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  actorId   String
  action    String
  targetId  String?
  message   String?
  details   String?
}
