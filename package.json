{
  "name": "amoravibe-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:seed": "prisma db seed"
  },
  "postinstall": "yarn workspace web run prisma:generate || true",
  "resolutions": {
    "jose": "6.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/react": "^7.0.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "next": "14.2.5",
    "pg": "^8.19.0",
    "playwright": "^1.58.2",
    "prettier": "^3.2.4",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.4.5",
    "encoding": "^0.1.13",
    "jose": "^6.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npx eslint --max-warnings=0 --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "npx prettier --check"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
