generator client {
  provider = "prisma-client-js"
  output   = "../generated/moderation-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModerationCaseStatus {
  OPEN
  INVESTIGATING
  ACTION_TAKEN
  CLOSED
  ARCHIVED
}

enum ModerationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModerationSource {
  USER_REPORT
  AUTOMATION
  DEVICE_SIGNAL
  TRUST_TEAM
}

enum ReportChannel {
  IN_APP
  EMAIL
  SUPPORT
}

enum CaseEventType {
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  ACTION_TAKEN
}

enum AutomationTriggerType {
  REPORT_CREATED
  CASE_ESCALATED
  SCHEDULED
}

model ModerationCase {
  id              String               @id @default(uuid())
  status          ModerationCaseStatus @default(OPEN)
  severity        ModerationSeverity   @default(MEDIUM)
  source          ModerationSource     @default(USER_REPORT)
  category        String
  summary         String
  description     String?
  reporterUserId  String?
  reportedUserId  String?
  assignedTo      String?
  metadata        Json?
  openedAt        DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  closedAt        DateTime?

  reports CaseReport[]
  events  CaseEvent[]
  runs    AutomationRun[]

  @@index([reportedUserId])
  @@index([status])
}

model CaseReport {
  id              String        @id @default(uuid())
  caseId          String?
  reporterUserId  String?
  reportedUserId  String?
  channel         ReportChannel @default(IN_APP)
  reason          String
  details         String?
  evidence        Json?
  status          String        @default("received")
  createdAt       DateTime      @default(now())

  case ModerationCase? @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([reportedUserId])
}

model CaseEvent {
  id        String        @id @default(uuid())
  caseId    String
  type      CaseEventType
  actorId   String?
  payload   Json?
  createdAt DateTime      @default(now())

  case ModerationCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
}

model AutomationRule {
  id          String                @id @default(uuid())
  name        String
  description String?
  trigger     AutomationTriggerType
  active      Boolean               @default(true)
  conditions  Json?
  action      Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  lastRunAt   DateTime?

  runs AutomationRun[]
}

model AutomationRun {
  id        String           @id @default(uuid())
  ruleId    String
  caseId    String?
  status    String
  details   Json?
  createdAt DateTime         @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id])
  case ModerationCase? @relation(fields: [caseId], references: [id])

  @@index([ruleId])
  @@index([caseId])
}
