{
  "version": 2,
  "framework": null,
  "installCommand": "npm install --workspaces=false",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [{ "src": "dist/lambda.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "^/api/(.*)$", "dest": "dist/lambda.js" },
    { "src": "^/(.*)$", "dest": "/" }
  ]
}
