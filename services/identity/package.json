{
  "name": "@amoravibe/identity-service",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node --files --project tsconfig.json src/main.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json && node ./scripts/copy-site.mjs",
    "start": "node dist/main.js",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "seed:mock": "ts-node --files --project tsconfig.json scripts/seed-mock-users.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.497.0",
    "@aws-sdk/s3-presigned-post": "^3.497.0",
    "@nestjs/common": "^10.3.3",
    "@nestjs/core": "^10.3.3",
    "@nestjs/platform-express": "^10.3.3",
    "@nestjs/schedule": "^6.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
