// Minimal SQLite schema for local development
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Core user model (simplified for SQLite)
model User {
  id                String      @id @default(uuid())
  legalName         String
  displayName       String
  dateOfBirth       DateTime
  email             String?     @unique
  phone             String?     @unique
  passwordHash      String
  gender            String      // SQLite: store as string
  orientation       String      // SQLite: store as string
  discoverySpace    String      // SQLite: store as string
  matchPreferences  String      // SQLite: store as JSON string
  city              String
  bio               String?
  photos            String?     // SQLite: store photos as JSON string
  trustScore        Int         @default(50)
  isVerified        Boolean     @default(false)
  visibility        String      @default("limited")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  sentLikes         UserLike[]  @relation("UserLikeSender")
  receivedLikes     UserLike[]  @relation("UserLikeReceiver")
}

// Like/action tracking
model UserLike {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("pending")  // SQLite: store as string (pending, matched, passed)
  highlight  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  sender     User     @relation("UserLikeSender", fields: [senderId], references: [id])
  receiver   User     @relation("UserLikeReceiver", fields: [receiverId], references: [id])
  
  @@index([senderId])
  @@index([receiverId])
}
