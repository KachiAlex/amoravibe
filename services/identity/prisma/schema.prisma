generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  man
  woman
  non_binary
  trans_man
  trans_woman
  self_describe
}

enum Orientation {
  heterosexual
  gay
  lesbian
  bisexual
  pansexual
  asexual
  queer
}

enum DiscoverySpace {
  straight
  lgbtq
  both
}

enum MatchPreference {
  men
  women
  everyone
}

enum VisibilityStatus {
  limited
  trusted
  restricted
}

enum VerificationIntent {
  verify_now
  skip
}

enum VerificationStatus {
  unverified
  pending
  verified
  flagged
}

model User {
  id                 String               @id @default(uuid())
  legalName          String
  displayName        String
  dateOfBirth        DateTime
  email              String?              @unique
  phone              String?              @unique
  passwordHash       String
  gender             Gender
  orientation        Orientation
  orientationPreferences String[]         @default([])
  discoverySpace     DiscoverySpace
  matchPreferences   MatchPreference[]    @default([])
  city               String
  bio                String?
  photos             Json?
  verificationIntent VerificationIntent   @default(skip)
  trustScore         Int                  @default(50)
  visibility         VisibilityStatus     @default(limited)
  isVerified         Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deviceFingerprints DeviceFingerprint[]
  verifications      Verification[]
}

model Verification {
  id        String             @id @default(uuid())
  userId    String
  provider  String
  status    VerificationStatus @default(pending)
  reference String?
  metadata  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model DeviceFingerprint {
  id         String   @id @default(uuid())
  userId     String?
  hash       String
  userAgent  String?
  riskLabel  String?
  signals    Json?
  observedAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
